DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ocr_db
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/ocr_db
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20
ALLOWED_EXTENSIONS=jpg,jpeg,png,bmp,tiff,webp,pdf
PADDLEOCR_LANG=en
DEBUG=true

# Auth
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Seed accounts (scripts/seed_admin.py) — change before running in any real env
SEED_ADMIN_NATIONAL_ID=000000000001
SEED_ADMIN_PASSWORD=change-me-admin
SEED_ADMIN_EMAIL=superadmin@local
SEED_ADMIN_FULL_NAME=Super Admin
SEED_WARD_OFFICER_NATIONAL_ID=000000000002
SEED_WARD_OFFICER_PASSWORD=change-me-ward
SEED_WARD_OFFICER_FULL_NAME=Ward Officer
SEED_WARD_NAME=Phường Mẫu
SEED_WARD_SLUG=phuong-mau
