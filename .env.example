DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ocr_db
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/ocr_db
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20
ALLOWED_EXTENSIONS=jpg,jpeg,png,bmp,tiff,webp,pdf
PADDLEOCR_LANG=en
DEBUG=true

# Auth
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
